{
  "name": "auratranslate",
  "private": true,
  "version": "0.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build",
    "package": "vite build && electron-builder",
    "electron": "electron .",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.antigravity.translator",
    "productName": "AuraTranslate",
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "asInvoker",
      "signExecutable": false
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.exe",
      "!dist/win-unpacked/**/*",
      "!dist/**/*.7z",
      "main.js",
      "preload.js",
      "package.json"
    ]
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
